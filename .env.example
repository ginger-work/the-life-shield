# The Life Shield — Backend Environment Variables
# Copy to .env and fill in production values
# Never commit this file with real secrets

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=your-secret-key-here-at-least-32-chars
APP_DEBUG=false
APP_PORT=8000

# ── Database (Railway PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/lifeshield_db

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-here-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe (Payment Processing) ───────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── SendGrid (Email) ──────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@thelifeshield.com
SENDGRID_FROM_NAME=The Life Shield

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://thelifeshield.com,https://your-vercel-app.vercel.app

# ── OpenAI (Tim Shaw AI) ──────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo

# ── Anthropic (Optional) ──────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here

# ── AWS S3 (Document Vault) ───────────────────────────────────
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=lifeshield-documents-vault

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Credit Bureau APIs (set BUREAU_SANDBOX_MODE=false for production) ─────
BUREAU_SANDBOX_MODE=true
# EQUIFAX_CLIENT_ID=
# EQUIFAX_CLIENT_SECRET=
# EXPERIAN_CLIENT_ID=
# EXPERIAN_CLIENT_SECRET=
# TRANSUNION_API_KEY=
# ISOFTPULL_API_KEY=
