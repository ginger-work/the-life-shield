# The Life Shield - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string-before-production
DEBUG=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lifeshield

# ── Redis (token revocation + rate limiting) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@thelifeshield.com
SMTP_PASSWORD=your-smtp-app-password
FROM_EMAIL=noreply@thelifeshield.com
FROM_NAME=The Life Shield

# ── Frontend URL (for email links) ───────────────────────────────────────────
FRONTEND_URL=https://thelifeshield.com

# ── CORS Allowed Origins ─────────────────────────────────────────────────────
# Comma-separated list (handled in config/security.py ALLOWED_ORIGINS list)
