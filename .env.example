# ============================================================
# THE LIFE SHIELD — Environment Variables
# Copy this file to .env and fill in all required values
# ============================================================

# --- Application ---
APP_ENV=development                      # development | production | test
APP_SECRET_KEY=CHANGE-ME-32-chars-min    # REQUIRED: 32+ random chars for JWT signing
APP_DEBUG=false                          # true in dev only
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=The Life Shield API
APP_VERSION=1.0.0

# --- Database ---
DATABASE_URL=postgresql://lifeshield:lifeshield_dev_password@localhost:5432/lifeshield_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false                      # Set true to log all SQL (dev only)

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT ---
JWT_SECRET_KEY=CHANGE-ME-JWT-SECRET      # REQUIRED: separate from APP_SECRET_KEY
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# --- Password Policy ---
BCRYPT_ROUNDS=12
MIN_PASSWORD_LENGTH=12

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://portal.thelifeshield.com

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500
FAILED_LOGIN_LOCKOUT_THRESHOLD=5
FAILED_LOGIN_LOCKOUT_DURATION_MINUTES=15

# --- TRGpay ---
TRGPAY_PUBLIC_KEY=trg_live_pk_cb3bf4b926824bf0ad7d0a45
TRGPAY_SECRET_KEY=trg_live_sk_027c5d03b9dc4ce6a5794c60

# --- Twilio (SMS + Voice) ---
TWILIO_ACCOUNT_SID=               # Required for SMS/Voice
TWILIO_AUTH_TOKEN=                # Required for SMS/Voice
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX  # Your Twilio number

# --- SendGrid (Email) ---
SENDGRID_API_KEY=                 # Required for email
SENDGRID_FROM_EMAIL=support@thelifeshield.com

# --- iSoftPull (Credit Reports) ---
ISOFTPULL_API_KEY=                # Required for credit pulls
ISOFTPULL_BASE_URL=https://api.isoftpull.com/v1

# --- Credit Bureau Direct APIs (optional) ---
EQUIFAX_CLIENT_ID=
EQUIFAX_CLIENT_SECRET=
EXPERIAN_API_KEY=
TRANSUNION_CLIENT_ID=
TRANSUNION_CLIENT_SECRET=

# --- Zoom (Video Sessions) ---
ZOOM_API_KEY=
ZOOM_API_SECRET=
ZOOM_WEBHOOK_SECRET=

# --- Security ---
ENCRYPTION_KEY=CHANGE-ME-32-byte-fernet-key  # For SSN encryption at rest

# --- Monitoring ---
SENTRY_DSN=                       # Optional: error tracking
