# =============================================================================
# THE LIFE SHIELD - Environment Configuration Template
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
DATABASE_URL=postgresql://lifeshield:lifeshield_dev_password@localhost:5432/lifeshield_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# --- Redis (caching + task queue) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT Authentication ---
JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# --- Password Policy ---
BCRYPT_ROUNDS=12
MIN_PASSWORD_LENGTH=12

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Twilio (SMS/Voice) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com/webhooks/twilio

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@thelifeshield.com
SENDGRID_FROM_NAME=The Life Shield

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=...
ELEVENLABS_DEFAULT_VOICE_ID=...

# --- AWS S3 (Document Vault) ---
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=lifeshield-documents-vault
AWS_S3_ENCRYPTION=AES256

# --- iSoftPull (Soft Credit Pulls) ---
ISOFTPULL_API_KEY=...
ISOFTPULL_BASE_URL=https://api.isoftpull.com/v1

# --- Google Cloud NLP ---
GOOGLE_CLOUD_PROJECT=...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Zoom ---
ZOOM_SDK_KEY=...
ZOOM_SDK_SECRET=...

# --- Sentry (Error Tracking) ---
SENTRY_DSN=https://...@sentry.io/...

# --- Mixpanel (Analytics) ---
MIXPANEL_TOKEN=...

# --- DNC List (FCC/TCPA Compliance) ---
DNC_API_KEY=...
DNC_API_BASE_URL=https://...

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500
FAILED_LOGIN_LOCKOUT_THRESHOLD=5
FAILED_LOGIN_LOCKOUT_DURATION_MINUTES=15

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
